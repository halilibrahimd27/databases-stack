# Bu proje Linux'ta çalışır. Tüm metin dosyalarını checkout'ta LF'e zorla —
# Windows'ta klonlanıp/kopyalanınca CRLF (\r) shebang'ları bozar:
#   bash: ./backup.sh: /bin/bash^M: bad interpreter: No such file or directory
* text=auto eol=lf

# Kritik çalıştırılabilir/parse edilen dosyalar — kesin LF
*.sh      text eol=lf
*.cnf     text eol=lf
*.conf    text eol=lf
crontab   text eol=lf
.env.example text eol=lf
