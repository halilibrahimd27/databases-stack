[client]
#password	= your_password
port		= 3306
socket		= /tmp/mysql.sock

[mysqld]
port		= 3306
socket		= /tmp/mysql.sock
datadir = /var/lib/mysql
default_storage_engine = InnoDB
skip-external-locking

# Karakter seti — compose `command:` bloğundan buraya taşındı.
# Bu dosya artık MariaDB ayarları için TEK yetki kaynağıdır (bkz. README).
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

key_buffer_size = 512M
max_allowed_packet = 100G
table_open_cache = 8000
table_definition_cache = 4000
# Per-connection buffer'lar canlı sistemden alındı: max_connections=1000 ile
# toplam bellek tavanını sınırlamak için KÜÇÜK tutulur. Bu, OOM düzeltmesinin
# ayrılmaz parçası — büyük değerler (ör. 8M sort+read) × 1000 bağlantı = OOM.
sort_buffer_size = 1M
join_buffer_size = 256K
net_buffer_length = 4K
read_buffer_size = 128K
read_rnd_buffer_size = 256K
myisam_sort_buffer_size = 128M
thread_cache_size = 64
query_cache_size = 256M
tmp_table_size = 32M
max_heap_table_size = 32M
sql-mode=NO_ENGINE_SUBSTITUTION,STRICT_TRANS_TABLES

#skip-name-resolve
max_connections = 1000
wait_timeout = 900
interactive_timeout = 900
max_connect_errors = 100
open_files_limit = 65535

#log-bin=mysql-bin
binlog_format=mixed
server-id = 1
expire_logs_days = 10
slow_query_log=1
slow-query-log-file=/var/lib/mysql/slow.log
long_query_time=2
#log_queries_not_using_indexes=on

innodb_data_home_dir = /var/lib/mysql
innodb_data_file_path = ibdata1:10M:autoextend
innodb_log_group_home_dir = /var/lib/mysql
innodb_buffer_pool_size = 3G
innodb_log_file_size = 512M
innodb_log_buffer_size = 256M
# 2 = her saniye diske flush (crash'te ≤1 sn son işlem riski). Yedekleme +
# donanım yükü altında I/O baskısını azaltır. Katı ACID isteyen 1'e çekmeli.
innodb_flush_log_at_trx_commit = 2
innodb_lock_wait_timeout = 50
innodb_max_dirty_pages_pct = 90
innodb_read_io_threads = 12
innodb_write_io_threads = 12

[mysqldump]
quick
max_allowed_packet = 1G
single-transaction
lock-tables = false
routines
triggers
events
add-drop-database
add-drop-table
complete-insert

[mysql]
no-auto-rehash

[myisamchk]
key_buffer_size = 512M
sort_buffer_size = 8M
read_buffer = 2M
write_buffer = 2M

[mysqlhotcopy]
interactive-timeout
