# =============================================================================
# Databases Stack — Ortam Değişkenleri (Şablon)
# =============================================================================
# Bu dosyayı .env olarak kopyalayın ve değerleri kendi ortamınıza göre
# doldurun. .env dosyası git'e commit ETMEYİN (.gitignore'da hariç tutulur).
# =============================================================================

# ─── Veritabanları için ortak parola (zorunlu) ────────────────────────
# MariaDB, PostgreSQL, MongoDB, Redis ve admin panellerinin tümü
# bu parolayı kullanır. Production'da 32+ karakter, rastgele üretilmiş.
#   openssl rand -base64 32
DB_PASSWORD=change-me-with-openssl-rand-base64-32

# ─── Container kaynak limitleri (docker-compose.yml) ──────────────────
# Hepsi ${VAR:-default} ile gelir; satırı silerseniz varsayılan kullanılır.
# Değiştirince `docker compose up -d` ile yeniden uygulanır.
# NOT: MariaDB'nin MOTOR ayarları (buffer pool, max_connections, log boyutu…)
# .env'de DEĞİL, mariadb/config/my.cnf içindedir (tek yetki kaynağı — bkz. README).
# MARIADB_MEM_LIMIT yalnızca container'ın bellek tavanıdır.
MARIADB_MEM_LIMIT=8G
POSTGRES_MEM_LIMIT=2G
MONGO_MEM_LIMIT=2G
# WiredTiger cache (GB) — MONGO_MEM_LIMIT'in altında tutun
MONGO_WIREDTIGER_CACHE_GB=1
REDIS_MEM_LIMIT=512M
# Redis'in kendi bellek tavanı — container limitinin altında olmalı
REDIS_MAXMEMORY=384mb

# ─── Backup script (backup.sh) ────────────────────────────────────────
# Stack'in root dizini (compose ile aynı yer). backup.sh .env'i burada arar.
DB_BASE_DIR=/opt/databases

# Backup dizini (varsayılan: ${DB_BASE_DIR}/backups) — ortam değişkeni olarak verin
# BACKUP_DIR=/mnt/backups

# Log dizini (varsayılan: ${DB_BASE_DIR}/logs) — ortam değişkeni olarak verin
# LOG_DIR=/var/log/databases

# Aşağıdakileri backup.sh doğrudan bu .env'den okur (ortam değişkeni önceliklidir):
# Yerel retention (gün) — backup.sh clean ve cron temizliği bunu kullanır
RETENTION_DAYS=7
# gzip seviyesi (1=hızlı … 9=en iyi; günlük yedek için 6 dengeli)
COMPRESSION_LEVEL=6
# MariaDB dump'ından hariç tutulacak tablolar (SQL LIKE, boşlukla ayrılır).
# Varsayılan: Laravel Telescope/Pulse. Devre dışı bırakmak için boş bırakın.
BACKUP_EXCLUDE_TABLE_PATTERNS=telescope% pulse%

# ─── App user (setup_db_users.sh) ─────────────────────────────────────
# Uygulamanın bağlanacağı kısıtlı kullanıcı (DROP yetkisi yok)
APP_USER=appuser
APP_PASSWORD=change-me-app-password

# ─── Setup script (sc.sh) ─────────────────────────────────────────────
# Nginx dashboard auth
NGINX_USER=root
# NGINX_PASS varsayılan olarak DB_PASSWORD'u kullanır

# ─── Google Drive sync (sync_remote.sh) ───────────────────────────────
# rclone remote adı (rclone config'den)
RCLONE_REMOTE_NAME=gdrive

# Google Drive'da yedek klasörü
GDRIVE_FOLDER=Database Backups

# Uzak retention (gün)
RETENTION_REMOTE_DAYS=30

# Sync aktif mi?
REMOTE_SYNC_ENABLED=true

# ─── Cassandra (opsiyonel) ─────────────────────────────────────────────
# Cassandra alt-stack'i kullanıyorsanız:
CASSANDRA_PASSWORD=change-me-cassandra-password
CASSANDRA_BASE_DIR=/opt/cassandra
